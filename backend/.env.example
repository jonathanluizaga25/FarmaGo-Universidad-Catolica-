# Copiar este archivo como .env y completar con valores reales
# NUNCA subir el archivo .env al repositorio
DB_USER=root
DB_PASSWORD=tu_password_local

# Para levantar el backend con la contrasena:
# Windows PowerShell:
# $env:DB_PASSWORD="tu_password"; cd backend; ./mvnw spring-boot:run
# Linux/Mac:
# export DB_PASSWORD=tu_password && cd backend && ./mvnw spring-boot:run